{
  "name": "@magicelk235/viaduct",
  "version": "1.4.5",
  "publishConfig": {
    "access": "public"
  },
  "description": "Convert a Chrome extension into a Safari Web Extension (macOS/iOS) ready for local dev or CI/CD.",
  "type": "module",
  "bin": {
    "viaduct": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc && node -e \"const f=require('node:fs');f.cpSync('src/templates','dist/templates',{recursive:true});f.cpSync('src/runtime','dist/runtime',{recursive:true})\" && node -e \"require('node:fs').chmodSync('dist/cli.js',0o755)\"",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "chrome-extension",
    "safari",
    "safari-web-extension",
    "web-extension",
    "converter",
    "manifest-v3",
    "macos",
    "xcode",
    "cli"
  ],
  "author": "magicelk235",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicelk235/Viaduct-CLI.git"
  },
  "bugs": {
    "url": "https://github.com/magicelk235/Viaduct-CLI/issues"
  },
  "homepage": "https://github.com/magicelk235/Viaduct-CLI#readme",
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
